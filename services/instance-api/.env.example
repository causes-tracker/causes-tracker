# Copy this file to .env and fill in the values.
# .env is gitignored — do not commit it.

DATABASE_URL=postgresql://causes:causes@postgres:5432/causes

# From Google Cloud Console → Credentials → OAuth 2.0 Client IDs
# Application type must be "TV and Limited Input devices".
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: export traces to Honeycomb. Leave blank to disable.
# Get a key at https://ui.honeycomb.io/account
HONEYCOMB_API_KEY=

# gRPC listen address (default shown)
# BIND_ADDR=[::]:50051
