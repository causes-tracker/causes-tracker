# Bazel 7+ default; explicit for clarity
common --enable_bzlmod

# Show output on failure
build --verbose_failures

# Required for buf lint via rules_lint: protoc must include source location info.
build --experimental_proto_descriptor_sets_include_source_info

# Local disk cache (shared across workspaces on the same machine)
build --disk_cache=~/.cache/bazel-disk-cache

# Workspace status: populates COMMIT_SHA and REPO_URL for BuildBuddy flake detection.
build --workspace_status_command="bash workspace_status.sh"

# CI config — activated with --config=ci in GitHub Actions.
# The API key is passed separately via --remote_header in the workflow.
build:ci --build_metadata=ROLE=CI
build:ci --remote_cache=grpcs://remote.buildbuddy.io
build:ci --bes_backend=grpcs://remote.buildbuddy.io
build:ci --bes_results_url=https://app.buildbuddy.io/invocation/

# Rust: use the experimental platform so the toolchain glibc constraint is satisfied.
# Without this, rules_rs toolchains (which embed gnu.2.28) cannot match the default
# @@platforms//host:host target platform.
build --platforms=@rules_rs//rs/experimental/platforms:x86_64-unknown-linux-gnu
build --extra_execution_platforms=@rules_rs//rs/experimental/platforms:x86_64-unknown-linux-gnu

# Lint aspects: run shellcheck and clippy automatically on all matching targets.
# No per-package wiring needed — aspects apply repo-wide.
build --aspects=//tools/lint:linters.bzl%shellcheck
build --aspects=//tools/lint:linters.bzl%clippy
build --output_groups=+rules_lint_human
build --@aspect_rules_lint//lint:fail_on_violation=true

# Coverage:
# Run with: bazel coverage //... && bazel run //tools:show_coverage
# ^// instruments all first-party targets; external crates (labels starting with @)
# are excluded automatically.
coverage --instrumentation_filter="^//"
# GENERATE_LLVM_LCOV must be set at action level so that Bazel's collect_coverage.sh
# invokes CC_CODE_COVERAGE_SCRIPT, the rules_rust binary that converts .profraw → LCOV.
# --action_env reaches collect_coverage.sh's process; RunEnvironmentInfo does not.
coverage --action_env=GENERATE_LLVM_LCOV=1

# Import user-local overrides (BuildBuddy API key, personal flags).
# This file is gitignored — copy .bazelrc.user.template to .bazelrc.user and fill it in.
try-import %workspace%/.bazelrc.user
